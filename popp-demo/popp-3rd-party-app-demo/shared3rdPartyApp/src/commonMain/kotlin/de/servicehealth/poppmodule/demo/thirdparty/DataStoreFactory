package de.servicehealth.poppmodule.demo.thirdparty

import android.content.Context
import androidx.datastore.core.DataStore
import androidx.datastore.preferences.core.Preferences
import androidx.datastore.preferences.preferencesDataStore

private val Context.dataStore: DataStore<Preferences> by preferencesDataStore(name = "favorites")

fun createFavoritesDataStore(context: Context): DataStore<Preferences> = context.dataStore