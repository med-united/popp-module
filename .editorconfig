root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = off
# Composable functions and KMP iOS entry points are intentionally PascalCase
ktlint_function_naming_ignore_when_annotated_with = Composable

# Compose resource generator emits lowercase object names (Res.drawable, Res.string)
# and PascalCase factory functions — disable naming rules for all generated code
[{**/build/generated/**/*.kt,**/build/generated/**/*.kts}]
ktlint_standard_class-naming = disabled
ktlint_standard_function-naming = disabled
